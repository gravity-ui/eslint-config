{
  "name": "@gravity-ui/eslint-config",
  "version": "4.2.1",
  "description": "Gravity UI ESLint config, following our styleguide",
  "keywords": [
    "eslint",
    "config"
  ],
  "license": "MIT",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/"
  ],
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "types": "./lib/index.d.ts"
    },
    "./a11y": {
      "import": "./lib/configs/a11y.js",
      "types": "./lib/configs/a11y.d.ts"
    },
    "./base": {
      "import": "./lib/configs/base.js",
      "types": "./lib/configs/base.d.ts"
    },
    "./client": {
      "import": "./lib/configs/client.js",
      "types": "./lib/configs/client.d.ts"
    },
    "./import-order": {
      "import": "./lib/configs/import-order.js",
      "types": "./lib/configs/import-order.d.ts"
    },
    "./prettier": {
      "import": "./lib/configs/prettier.js",
      "types": "./lib/configs/prettier.d.ts"
    },
    "./react": {
      "import": "./lib/configs/react.js",
      "types": "./lib/configs/react.d.ts"
    },
    "./server": {
      "import": "./lib/configs/server.js",
      "types": "./lib/configs/server.d.ts"
    },
    "./typescript": {
      "import": "./lib/configs/typescript.js",
      "types": "./lib/configs/typescript.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gravity-ui/eslint-config"
  },
  "bugs": {
    "url": "https://github.com/gravity-ui/eslint-config/issues"
  },
  "homepage": "https://github.com/gravity-ui/eslint-config#readme",
  "scripts": {
    "prepare": "husky",
    "test": "echo \"Error: no test specified\" && exit 0",
    "lint": "npm run lint:js && npm run lint:prettier",
    "lint:js": "NODE_OPTIONS='--experimental-strip-types --import ./node-helpers/register.js' eslint . --report-unused-disable-directives --flag unstable_config_lookup_from_file --flag unstable_native_nodejs_ts_config",
    "lint:prettier": "npm run prettier -- --check",
    "prettier": "prettier '**/*.{md,yaml,yml,json}'",
    "build": "tsc -p tsconfig.publish.json",
    "prepublishOnly": "npm run -s build"
  },
  "dependencies": {
    "@babel/core": "^7.26.10",
    "@babel/eslint-parser": "^7.27.0",
    "@babel/preset-react": "^7.26.3",
    "@eslint/js": "^9.23.0",
    "@stylistic/eslint-plugin": "^4.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-import-resolver-typescript": "^4.3.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^50.6.9",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-security-node": "^1.1.4",
    "globals": "^16.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@gravity-ui/prettier-config": "^1.1.0",
    "@gravity-ui/tsconfig": "^1.0.0",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/eslint-plugin-security": "^3.0.1",
    "eslint": "^9.24.0",
    "husky": "^9.1.7",
    "nano-staged": "^0.8.0",
    "prettier": "^3.5.3",
    "react": "^19.1.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "prettier": "^3.0.0",
    "typescript": "^5.8.3"
  },
  "peerDependenciesMeta": {
    "prettier": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22.13.0",
      "onFail": "error"
    }
  },
  "nano-staged": {
    "*.{js,ts}": [
      "eslint --fix --quiet --report-unused-disable-directives --flag unstable_native_nodejs_ts_config"
    ],
    "*.{md,yaml,yml,json}": [
      "prettier --write"
    ]
  }
}
